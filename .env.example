# OTONOM — Variables serveur (Nuxt runtimeConfig).
# Copier en « .env » (jamais commité) et remplir. En prod N0C : définir ces variables
# dans le panneau de l'app Node (mêmes noms).

# Base de données
# — En LOCAL : laisser les NUXT_MYSQL_* vides → SQLite (fichier ci-dessous).
NUXT_DB_FILE=./data/otonom.db
# — En PROD (PlanetHoster N0C) : créer la base MySQL + un utilisateur dans le panneau,
#   puis renseigner ces 5 variables (dès que HOST est rempli, l'app passe sur MySQL,
#   et crée les tables toute seule au 1er démarrage).
NUXT_MYSQL_HOST=
NUXT_MYSQL_PORT=3306
NUXT_MYSQL_USER=
NUXT_MYSQL_PASSWORD=
NUXT_MYSQL_DATABASE=

# Destinataires par défaut des leads (repli si un formulaire n'a pas de réglage)
NUXT_DEFAULT_RECIPIENTS=e.barlet@mc-groupe.com, a.thomas@mc-groupe.com

# Back-office admin
NUXT_ADMIN_PASSWORD=CHOISIR_UN_MOT_DE_PASSE_FORT
# Clé de chiffrement des sessions (≥ 32 caractères aléatoires) — obligatoire en prod
NUXT_SESSION_PASSWORD=REMPLACER_PAR_32_CARACTERES_ALEATOIRES_MIN

# SMTP (boîte no-reply@otonom.fr — PlanetHoster)
NUXT_SMTP_HOST=node251-eu.n0c.com
NUXT_SMTP_PORT=465
NUXT_SMTP_SECURE=true
NUXT_SMTP_USER=no-reply@otonom.fr
NUXT_SMTP_PASS=REMPLACER_LE_MOT_DE_PASSE
NUXT_SMTP_FROM=no-reply@otonom.fr
NUXT_SMTP_FROM_NAME=OTONOM — Site
