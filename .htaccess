# OTONOM — sécurité de base (PlanetHoster / Apache-LiteSpeed)

# 1) Bloquer l'accès direct aux fichiers de config et sensibles
<FilesMatch "(^\.|\.(config|secret|example)\.php$|composer\.(json|lock)$|\.md$)">
  Require all denied
</FilesMatch>

# 2) Empêcher l'exécution/listage du dossier de la librairie PHPMailer
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>
RewriteEngine On
RewriteRule ^lib/ - [F,L]

# 3) Ne pas divulguer les fichiers cachés (.git, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
